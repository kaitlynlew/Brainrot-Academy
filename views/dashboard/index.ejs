<%- include('../partials/header') %>

<div class="dashboard-page">
  <div class="container">

    <!-- Profile Header -->
    <div class="dash-profile">
      <div class="dash-avatar"><%= user.avatar_emoji %></div>
      <div class="dash-profile-info">
        <h1><%= user.username %></h1>
        <p>Level <%= stats.level %> Scholar · <%= stats.xp %> XP total</p>
        <div class="streak-badge">🔥 <%= stats.streak %>-day streak</div>
      </div>
      <div class="dash-xp-bar-wrap">
        <div class="dash-xp-label">
          <span>Level <%= stats.level %></span>
          <span><%= stats.xpProgress %>/100 XP to Level <%= stats.level + 1 %></span>
        </div>
        <div class="dash-xp-bar">
          <div class="dash-xp-fill" style="width: <%= stats.xpProgress %>%"></div>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-icon">📚</span>
        <div class="stat-num"><%= stats.learned %></div>
        <div class="stat-label">Terms Learned</div>
        <div class="stat-sub">of <%= stats.total %> total</div>
        <div class="stat-mini-bar">
          <div style="width: <%= Math.min(100, Math.round(stats.learned/stats.total*100)) %>%"></div>
        </div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">⭐</span>
        <div class="stat-num"><%= stats.xp %></div>
        <div class="stat-label">Total XP</div>
        <div class="stat-sub">Level <%= stats.level %></div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🔥</span>
        <div class="stat-num"><%= stats.streak %></div>
        <div class="stat-label">Day Streak</div>
        <div class="stat-sub">Login daily to keep it going</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">🎯</span>
        <div class="stat-num"><%= stats.bestQuiz %></div>
        <div class="stat-label">Best Quiz Score</div>
        <div class="stat-sub"><%= stats.avgPct %>% avg accuracy</div>
      </div>
      <div class="stat-card">
        <span class="stat-icon">📝</span>
        <div class="stat-num"><%= stats.notes %></div>
        <div class="stat-label">Notes Written</div>
        <div class="stat-sub"><a href="/notes">View all →</a></div>
      </div>
    </div>

    <div class="dash-row">
      <!-- Recent Quiz Attempts -->
      <div class="dash-panel">
        <div class="dash-panel-header">
          <h2>Recent Quiz Attempts</h2>
          <a href="/quiz" class="btn btn-sm btn-outline">Take Quiz</a>
        </div>
        <% if (recentAttempts.length === 0) { %>
          <p class="empty-hint">No quizzes taken yet. Go test yourself! 🎯</p>
        <% } else { %>
          <div class="attempt-list">
            <% recentAttempts.forEach(a => { %>
              <div class="attempt-row">
                <span class="attempt-diff attempt-diff-<%= a.difficulty %>"><%= a.difficulty || 'mixed' %></span>
                <span class="attempt-score"><%= a.score %> / <%= a.total_questions %></span>
                <span class="attempt-pct"><%= Math.round(a.score/a.total_questions*100) %>%</span>
                <span class="attempt-date"><%= new Date(a.completed_at).toLocaleDateString() %></span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Recently Learned Terms -->
      <div class="dash-panel">
        <div class="dash-panel-header">
          <h2>Recently Learned</h2>
          <a href="/learn" class="btn btn-sm btn-outline">Browse All</a>
        </div>
        <% if (recentTerms.length === 0) { %>
          <p class="empty-hint">Mark terms as learned in the dictionary! 📚</p>
        <% } else { %>
          <div class="learned-list">
            <% recentTerms.forEach(t => { %>
              <div class="learned-row">
                <span class="learned-term"><%= t.term %></span>
                <span class="learned-def"><%= t.definition.substring(0, 50) %>...</span>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="dash-actions">
      <h2>Quick Actions</h2>
      <div class="action-row">
        <a href="/learn" class="action-btn">📚 Continue Learning</a>
        <a href="/quiz/play?difficulty=all" class="action-btn">🎯 Quick Quiz</a>
        <a href="/notes/new" class="action-btn">📝 New Note</a>
        <a href="/quiz/leaderboard" class="action-btn">🏆 Leaderboard</a>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
