<%- include('../partials/header') %>

<div class="page-header">
  <div class="container">
    <h1>🏆 Leaderboard</h1>
    <p>The most based scholars at Brainrot Academy. No cap.</p>
  </div>
</div>

<div class="container leaderboard-container">

  <% if (leaders.length === 0) { %>
    <div class="empty-state">
      <p>No players yet! Be the first — take a quiz and claim the #1 spot 💀</p>
      <a href="/quiz" class="btn btn-primary">Take a Quiz</a>
    </div>
  <% } else { %>

    <% if (leaders.length >= 3) { %>
      <div class="podium">
        <!-- 2nd place -->
        <div class="podium-slot podium-2">
          <span class="podium-avatar"><%= leaders[1].avatar_emoji %></span>
          <span class="podium-name"><%= leaders[1].username %></span>
          <span class="podium-xp"><%= leaders[1].xp %> XP</span>
          <div class="podium-block p2-block">2nd 🥈</div>
        </div>
        <!-- 1st place -->
        <div class="podium-slot podium-1">
          <span class="podium-crown">👑</span>
          <span class="podium-avatar"><%= leaders[0].avatar_emoji %></span>
          <span class="podium-name"><%= leaders[0].username %></span>
          <span class="podium-xp"><%= leaders[0].xp %> XP</span>
          <div class="podium-block p1-block">1st 🥇</div>
        </div>
        <!-- 3rd place -->
        <div class="podium-slot podium-3">
          <span class="podium-avatar"><%= leaders[2].avatar_emoji %></span>
          <span class="podium-name"><%= leaders[2].username %></span>
          <span class="podium-xp"><%= leaders[2].xp %> XP</span>
          <div class="podium-block p3-block">3rd 🥉</div>
        </div>
      </div>
    <% } %>

    <table class="leaderboard-table">
      <thead>
        <tr>
          <th>Rank</th>
          <th>Player</th>
          <th>XP</th>
          <th>Streak</th>
          <th>Best Score</th>
          <th>Quizzes</th>
        </tr>
      </thead>
      <tbody>
        <% leaders.forEach((l, i) => { %>
          <tr class="<%= user && l.username === user.username ? 'my-row' : '' %>">
            <td class="rank-col">
              <% if (i === 0) { %> 🥇
              <% } else if (i === 1) { %> 🥈
              <% } else if (i === 2) { %> 🥉
              <% } else { %> #<%= i + 1 %>
              <% } %>
            </td>
            <td class="player-col">
              <span class="lb-avatar"><%= l.avatar_emoji %></span>
              <span class="lb-name"><%= l.username %></span>
              <% if (user && l.username === user.username) { %><span class="you-badge">you</span><% } %>
            </td>
            <td><strong><%= l.xp %></strong></td>
            <td>🔥 <%= l.streak %></td>
            <td><%= l.best_score || 0 %></td>
            <td><%= l.attempts || 0 %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

  <% } %>

  <div class="lb-cta">
    <a href="/quiz" class="btn btn-primary">Take a Quiz →</a>
    <% if (!user) { %>
      <a href="/register" class="btn btn-outline">Join to Compete</a>
    <% } %>
  </div>

</div>

<%- include('../partials/footer') %>
