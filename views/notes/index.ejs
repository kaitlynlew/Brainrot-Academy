<%- include('../partials/header') %>

<div class="page-header">
  <div class="container notes-page-header">
    <div>
      <h1>📝 My Notes</h1>
      <p>Jot down slang, vocab, or anything brainrot-related. Your private notes fr fr.</p>
    </div>
    <a href="/notes/new" class="btn btn-primary">+ New Note</a>
  </div>
</div>

<div class="container notes-container">

  <% if (notes.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📝</div>
      <h3>No notes yet bestie</h3>
      <p>Start writing notes about slang terms, quiz tips, or anything you want to remember.</p>
      <a href="/notes/new" class="btn btn-primary">Create First Note</a>
    </div>
  <% } else { %>
    <div class="notes-grid">
      <% notes.forEach(note => { %>
        <div class="note-card note-<%= note.color %> <%= note.pinned ? 'note-pinned' : '' %>">
          <% if (note.pinned) { %><span class="pin-badge">📌 Pinned</span><% } %>
          <h3 class="note-title"><%= note.title %></h3>
          <p class="note-content"><%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '...' : '' %></p>
          <div class="note-footer">
            <span class="note-date"><%= new Date(note.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
            <div class="note-actions">
              <form action="/notes/<%= note.id %>/pin" method="POST" style="display:inline">
                <button type="submit" class="note-btn" title="<%= note.pinned ? 'Unpin' : 'Pin' %>">
                  <%= note.pinned ? '📍' : '📌' %>
                </button>
              </form>
              <a href="/notes/<%= note.id %>/edit" class="note-btn" title="Edit">✏️</a>
              <form action="/notes/<%= note.id %>/delete" method="POST" style="display:inline"
                    onsubmit="return confirm('Delete this note? No cap this is permanent.')">
                <button type="submit" class="note-btn note-delete-btn" title="Delete">🗑️</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>

<%- include('../partials/footer') %>
