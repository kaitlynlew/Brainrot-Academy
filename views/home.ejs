<%- include('partials/header') %>

<section class="hero">
  <div class="hero-blob hero-blob--1" aria-hidden="true"></div>
  <div class="hero-blob hero-blob--2" aria-hidden="true"></div>
  <div class="hero-blob hero-blob--3" aria-hidden="true"></div>
  <div class="hero-noise"></div>
  <div class="hero-content">
    <div class="hero-badge">✨ NO CAP EDUCATION FR FR</div>
    <h1 class="hero-title">
      Learn Gen Z Slang<br>
      <span class="hero-accent">Without Being Delulu</span>
    </h1>
    <p class="hero-sub">
      Master 30+ terms, crush quizzes, and finally understand<br>what the internet is saying. It's giving Duolingo but make it brainrot.
    </p>
    <div class="hero-cta">
      <a href="/learn" class="btn btn-primary btn-lg">📚 Start Learning</a>
      <a href="/quiz" class="btn btn-outline btn-lg">🎯 Take a Quiz</a>
    </div>
    <div class="hero-stats">
      <div class="stat-pill">30+ Slang Terms</div>
      <div class="stat-pill">15 Quiz Questions</div>
      <div class="stat-pill">Free Forever</div>
    </div>
  </div>
  <div class="hero-visual">
    <div class="floating-cards">
      <div class="float-card fc1">no cap 🧢</div>
      <div class="float-card fc2">bussin 🔥</div>
      <div class="float-card fc3">rizz ✨</div>
      <div class="float-card fc4">slay 💅</div>
      <div class="float-card fc5">mid 😐</div>
      <div class="float-card fc6">W 🏆</div>
    </div>
  </div>
</section>

<section class="features-section">
  <div class="container">
    <h2 class="section-title">What's the vibe?</h2>
    <div class="features-grid">
      <a href="/learn" class="feature-card">
        <div class="feature-icon">📚</div>
        <h3>Learn</h3>
        <p>Definitions, examples, origins, and media for every term. Filter by category or difficulty.</p>
        <span class="feature-cta">Start learning →</span>
      </a>
      <a href="/quiz" class="feature-card">
        <div class="feature-icon">🎯</div>
        <h3>Quiz</h3>
        <p>Test your knowledge with multiple-choice quizzes. Earn XP and climb the leaderboard.</p>
        <span class="feature-cta">Take quiz →</span>
      </a>
      <a href="/notes" class="feature-card">
        <div class="feature-icon">📝</div>
        <h3>Notes</h3>
        <p>Save your own notes, vocab lists, or anything you want to remember. Full CRUD support.</p>
        <span class="feature-cta">My notes →</span>
      </a>
      <a href="/register" class="feature-card">
        <div class="feature-icon">🏆</div>
        <h3>Progress</h3>
        <p>Track your XP, daily streak, learned terms, and quiz stats on your personal dashboard.</p>
        <span class="feature-cta">Join free →</span>
      </a>
    </div>
  </div>
</section>

<section class="preview-section">
  <div class="container">
    <h2 class="section-title">Today's Terms 🔥</h2>
    <div class="preview-grid">
      <div class="preview-card">
        <span class="preview-term">rizz</span>
        <span class="preview-tag">dating</span>
        <p>Natural charm or the ability to attract others through charisma. "He's got unspoken rizz."</p>
      </div>
      <div class="preview-card">
        <span class="preview-term">no cap</span>
        <span class="preview-tag">general</span>
        <p>Truthfully; for real. Emphasizes you're not lying. "That movie was fire, no cap."</p>
      </div>
      <div class="preview-card">
        <span class="preview-term">delulu</span>
        <span class="preview-tag">dating</span>
        <p>Short for delusional. Having unrealistic expectations, usually about relationships.</p>
      </div>
    </div>
    <div class="preview-action">
      <a href="/learn" class="btn btn-primary">See All Terms →</a>
    </div>
  </div>
</section>

<section class="brainrot-section">
  <div class="container">
    <h2 class="section-title">🍕 Italian Brainrot Characters</h2>
    <p class="section-sub">The bizarre viral meme universe taking the internet by storm</p>
    <div class="character-teaser">
      <div class="char-pill">Tralalero Tralala</div>
      <div class="char-pill">Bombardiro Crocodilo</div>
      <div class="char-pill">Tung Tung Sahur</div>
      <div class="char-pill">Cappuccino Assassino</div>
      <div class="char-pill">Bombombini Gusini</div>
    </div>
    <a href="/learn/characters/brainrot" class="btn btn-outline">Explore Characters →</a>
  </div>
</section>

<%- include('partials/footer') %>
