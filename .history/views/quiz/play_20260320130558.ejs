<%- include('../partials/header') %>

  <div class="container quiz-play-container" data-total="<%= questions.length %>">

    <div class="quiz-progress-bar-wrap">
      <div class="quiz-progress-bar" id="progressBar" style="width: 0%"></div>
    </div>

    <div class="quiz-header">
      <span id="questionCounter">Question 1 / <%= questions.length %></span>
      <span id="scoreDisplay">Score: 0</span>
      <span class="diff-pill diff-<%= difficulty %>">
        <%= difficulty %>
      </span>
    </div>

    <!-- Questions -->
    <div id="quizArea">
      <% questions.forEach((q, i)=> { %>
        <div class="quiz-question-block <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>"
          data-correct="<%= q.correct_answer %>">
          <div class="question-text">
            <span class="q-num">Q<%= i + 1 %></span>
            <%= q.question %>
          </div>
          <div class="options-grid">
            <% const options=[q.option_a, q.option_b, q.option_c, q.option_d]; const shuffled=options .map(o=> ({ o,
              sort: Math.random() }))
              .sort((a, b) => a.sort - b.sort)
              .map(x => x.o);
              %>
              <% shuffled.forEach((opt, oi)=> { %>
                <button class="option-btn" data-answer="<%= opt %>">
                  <span class="option-letter">
                    <%= ['A','B','C','D'][oi] %>
                  </span>
                  <%= opt %>
                </button>
                <% }) %>
          </div>
          <div class="feedback-box" id="feedback-<%= i %>" style="display:none"></div>
          <div class="quiz-nav" style="display:none">
            <% if (i < questions.length - 1) { %>
              <button class="btn btn-primary next-btn" data-next="<%= i + 1 %>">Next Question →</button>
              <% } else { %>
                <button class="btn btn-primary" id="finishBtn">See Results 🏆</button>
                <% } %>
          </div>
        </div>
        <% }) %>
    </div>

    <!-- Results Screen -->
    <div id="resultsScreen" style="display:none" class="results-screen">
      <div class="results-card">
        <div class="results-emoji" id="resultsEmoji">🏆</div>
        <h2 id="resultsTitle">Quiz Complete!</h2>
        <div class="results-score">
          <span id="finalScore">0</span> / <%= questions.length %>
        </div>
        <div class="results-pct" id="resultsPct"></div>
        <div class="results-msg" id="resultsMsg"></div>
        <% if (user) { %>
          <div class="xp-earned" id="xpEarned"></div>
          <% } %>
            <div class="results-actions">
              <a href="/quiz/play?difficulty=<%= difficulty %>" class="btn btn-primary">Try Again 🔄</a>
              <a href="/quiz" class="btn btn-outline">Back to Quiz</a>
              <a href="/quiz/leaderboard" class="btn btn-ghost">🏆 Leaderboard</a>
            </div>
      </div>
    </div>

  </div>

  <script>
    // Total questions count used for progress/results UI.
    const totalQ = parseInt(document.querySelector('.quiz-play-container').dataset.total, 10);
    let currentQ = 0;
    let score = 0;
    const difficulty = '<%= difficulty %>';

    function updateProgress() {
      const pct = ((currentQ) / totalQ) * 100;
      document.getElementById('progressBar').style.width = pct + '%';
      document.getElementById('questionCounter').textContent = `Question ${currentQ + 1} / ${totalQ}`;
      document.getElementById('scoreDisplay').textContent = `Score: ${score}`;
    }

    document.querySelectorAll('.option-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const block = this.closest('.quiz-question-block');
        const idx = parseInt(block.dataset.index);
        if (block.classList.contains('answered')) return;
        block.classList.add('answered');

        const chosen = this.dataset.answer;
        const correct = block.dataset.correct;
        const feedback = document.getElementById('feedback-' + idx);
        const nav = block.querySelector('.quiz-nav');

        // Disable all options
        block.querySelectorAll('.option-btn').forEach(b => {
          b.disabled = true;
          if (b.dataset.answer === correct) b.classList.add('correct');
          else if (b === this) b.classList.add('wrong');
        });

        if (chosen === correct) {
          score++;
          feedback.className = 'feedback-box feedback-correct';
          feedback.textContent = '✅ No cap, that\'s correct!';
        } else {
          feedback.className = 'feedback-box feedback-wrong';
          feedback.textContent = `❌ It's giving wrong. Correct answer: "${correct}"`;
        }
        feedback.style.display = 'block';
        nav.style.display = 'flex';
        document.getElementById('scoreDisplay').textContent = `Score: ${score}`;
      });
    });

    document.querySelectorAll('.next-btn').forEach(btn => {
      btn.addEventListener('click', function () {
        const nextIdx = parseInt(this.dataset.next);
        document.querySelectorAll('.quiz-question-block').forEach(b => b.classList.remove('active'));
        document.querySelector(`.quiz-question-block[data-index="${nextIdx}"]`).classList.add('active');
        currentQ = nextIdx;
        updateProgress();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    const finishBtn = document.getElementById('finishBtn');
    if (finishBtn) {
      finishBtn.addEventListener('click', async () => {
        document.getElementById('quizArea').style.display = 'none';
        const rs = document.getElementById('resultsScreen');
        rs.style.display = 'block';

        const pct = Math.round((score / totalQ) * 100);
        document.getElementById('finalScore').textContent = score;
        document.getElementById('resultsPct').textContent = `${pct}% correct`;
        document.getElementById('progressBar').style.width = '100%';

        const msgs = [
          [0, 30, '💀 L fr fr. Touch grass and study more.', '😬'],
          [30, 60, 'Not bad, kinda mid tbh. You got potential bestie.', '😐'],
          [60, 80, 'Lowkey bussin! You understood the assignment mostly.', '🔥'],
          [80, 99, 'You ate and left no crumbs! Based performance.', '✨'],
          [100, 101, 'SLAY! No cap you\'re a certified brainrot scholar fr fr!', '👑']
        ];
        const [, , msg, emoji] = msgs.find(([lo, hi]) => pct >= lo && pct < hi) || msgs[msgs.length - 1];
        document.getElementById('resultsMsg').textContent = msg;
        document.getElementById('resultsEmoji').textContent = emoji;

        // Submit score
        try {
          const resp = await fetch('/quiz/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ score, total: totalQ, difficulty })
          });
          const data = await resp.json();
          const xpEl = document.getElementById('xpEarned');
          if (xpEl && data.success && data.xp !== null) {
            xpEl.textContent = `+${score * 20} XP earned! Total: ${data.xp} XP ⭐`;
            xpEl.style.display = 'block';
          }
        } catch (e) { /* silent */ }
      });
    }

    updateProgress();
  </script>

  <%- include('../partials/footer') %>